# Copie este arquivo para ".env" e preencha com os valores reais.
# NUNCA versione o .env real (adicione no .gitignore).

# --- Banco de dados (SQL Server) ---
DB_SERVER=192.168.1.10
DB_PORT=1433
DB_NAME=meu_banco
DB_USER=usuario_app
DB_PASSWORD=troque_esta_senha
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# --- API ---
PORT=3000
CORS_ORIGIN=http://192.168.1.20:5173

# --- Autenticação (JWT) ---
JWT_SECRET=troque_por_uma_string_longa_e_aleatoria
JWT_EXPIRES_IN=8h
